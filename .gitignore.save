/coverage

# Production
/build
/out
/.next
/dist

# Misc
.DS_Store
*.pem
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor
.vscode/
.idea/
*.swp
*.swo
*~
.code-workspace

# IDE
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Sensitive files
.env.production
secrets.json

# OS
Thumbs.db
.AppleDouble
.LSOverride
*.zip
*.rar

